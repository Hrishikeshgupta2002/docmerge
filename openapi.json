{
  "openapi": "3.1.0",
  "info": {
    "title": "DocMerge API",
    "description": "A production-ready API for merging DOCX documents.\n\n## Features\n\n* **Merge Documents**: Combine multiple DOCX files into a single document with enterprise-grade merging\n* **Preserves Formatting**: Headers, footers, section breaks, and complex layouts are maintained\n\n## Technology Stack\n\n* FastAPI for high-performance async API\n* docxcompose.Composer for enterprise-grade document merging\n* Docker-based deployment for consistent environments\n* Railway-ready with optimized configuration\n\n## Endpoints\n\n* `POST /merge-docx/` - Merge multiple DOCX files\n* `GET /` - Health check endpoint\n* `GET /info` - API information and capabilities",
    "version": "1.0.0",
    "contact": {
      "name": "DocMerge API",
      "url": "https://docmerge-production.up.railway.app"
    },
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "url": "https://docmerge-production.up.railway.app",
      "description": "Production server"
    },
    {
      "url": "http://localhost:8080",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Documents",
      "description": "Document merging operations."
    },
    {
      "name": "Health",
      "description": "Health check and API information endpoints."
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": ["Health"],
        "summary": "API Health Check",
        "description": "Check if the API is running properly",
        "operationId": "health_check__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "healthy"
                    },
                    "message": {
                      "type": "string",
                      "example": "DocMerge API is running"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/info": {
      "get": {
        "tags": ["Health"],
        "summary": "API Information",
        "description": "Get information about the API capabilities",
        "operationId": "api_info_info_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "title": {
                      "type": "string",
                      "example": "DocMerge API"
                    },
                    "version": {
                      "type": "string",
                      "example": "1.0.0"
                    },
                    "description": {
                      "type": "string",
                      "example": "API for merging DOCX files"
                    },
                    "features": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "endpoints": {
                      "type": "object",
                      "properties": {
                        "merge": {
                          "type": "object",
                          "properties": {
                            "path": {
                              "type": "string",
                              "example": "/merge-docx/"
                            },
                            "method": {
                              "type": "string",
                              "example": "POST"
                            },
                            "description": {
                              "type": "string"
                            },
                            "params": {
                              "type": "string"
                            },
                            "requirements": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/merge-docx/": {
      "post": {
        "tags": ["Documents"],
        "summary": "Merge multiple DOCX files",
        "description": "Upload multiple DOCX files to merge them into a single document using enterprise-grade merging",
        "operationId": "merge_files_merge_docx__post",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "files": {
                    "title": "Files",
                    "description": "List of DOCX files to merge (minimum 2 files required)",
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  }
                },
                "required": ["files"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/vnd.openxmlformats-officedocument.wordprocessingml.document": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            },
            "headers": {
              "Content-Disposition": {
                "schema": {
                  "type": "string"
                },
                "description": "attachment; filename=merged_document.docx"
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid input or validation error"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {}
  }
}

